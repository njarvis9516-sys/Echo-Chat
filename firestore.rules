rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isServerMember(serverId) {
      return isSignedIn() && exists(/databases/$(database)/documents/servers/$(serverId)/members/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'njarvis9516@gmail.com' && request.auth.token.email_verified == true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation helpers
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (!('username' in data) || (data.username is string && data.username.size() <= 32 && data.username.matches('^[a-z0-9_]+$'))) &&
             (!('customStatus' in data) || (data.customStatus is string && data.customStatus.size() <= 100)) &&
             data.status in ['online', 'idle', 'dnd', 'offline'];
    }

    function isValidServer(data) {
      return data.keys().hasAll(['name', 'ownerId', 'createdAt', 'memberIds']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.memberIds is list && data.memberIds.size() > 0 &&
             (!('iconURL' in data) || (data.iconURL is string && data.iconURL.size() <= 2048));
    }

    function isValidMessage(data) {
      return data.userId == request.auth.uid &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 2000;
    }

    function isValidNotification(data) {
      return data.userId is string &&
             data.type == 'mention' &&
             data.fromUserId == request.auth.uid &&
             data.content is string && data.content.size() <= 2048 &&
             data.read == false;
    }

    // User profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    // Servers
    match /servers/{serverId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid in resource.data.get('memberIds', [])) || 
        (resource.data.get('ownerId', '') == request.auth.uid)
      );
      allow create: if isSignedIn() && isValidServer(incoming()) && incoming().ownerId == request.auth.uid && (request.auth.uid in incoming().memberIds);
      allow update: if isSignedIn() && 
                    (resource.data.ownerId == request.auth.uid || isAdmin()) && 
                    isValidServer(incoming()) &&
                    incoming().ownerId == resource.data.ownerId;
      allow delete: if isSignedIn() && (resource.data.ownerId == request.auth.uid || isAdmin());

      // Server Members
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (isOwner(memberId) || get(/databases/$(database)/documents/servers/$(serverId)).data.ownerId == request.auth.uid);
      }

      // Channels
      match /channels/{channelId} {
        // Allow reading channels if signed in (Discord allows discovery) or more strictly if a member.
        // Loosening to isSignedIn() for now to handle potential race conditions during server creation.
        allow read: if isSignedIn();
        allow create, update: if isSignedIn() && get(/databases/$(database)/documents/servers/$(serverId)).data.ownerId == request.auth.uid;
      }
    }

    // Messages - Top level for flatter queries
    match /channels/{channelId}/messages/{messageId} {
      // Use resource.data for reads - incoming() is for writes
      allow read: if isSignedIn(); 
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidMessage(incoming());
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Voice States
    match /voiceStates/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && incoming().userId == request.auth.uid;
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId) || (isSignedIn() && get(/databases/$(database)/documents/servers/$(resource.data.serverId)).data.ownerId == request.auth.uid);
    }
    
    // Video Signals (WebRTC)
    match /videoSignals/{signalId} {
      allow list, get: if isSignedIn() && resource.data.to == request.auth.uid;
      allow create: if isSignedIn() && incoming().from == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.to == request.auth.uid;
    }
    
    // Notifications
    match /notifications/{notificationId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
